# VoiceTTSr - .gitignore

# Virtual Environments (Bulky)
*-env/
*-env*/
venv/
.venv/

# User Data & Shared Folders (Directories exist, contents ignored)
Output/*
!Output/.gitkeep

references/*
!references/qwen/
!references/xtts/
!references/chatterbox/
references/qwen/*
!references/qwen/.gitkeep
references/xtts/*
!references/xtts/.gitkeep
references/chatterbox/*
!references/chatterbox/.gitkeep

Profiles/*
!Profiles/.gitkeep

# Private Assets (Entirely Excluded)
voice_files/
_backup/

# Models & Large Binaries
rvc_models/*.pt
rvc_models/*.pth
rvc_models/*.index
speaker_latents.pt

# System & OS Files
__pycache__/
*.py[cod]
*$py.class
.DS_Store
Thumbs.db
*.log
*.bak
*.tmp

# Local Runtime Artifacts
voicecloner_config.json
icon.png
create_shortcut.ps1
.temp_ag_kit/
.agent/

# Agent Protocol Files
CLAUDE.md
MEMORIES.md
KNOWLEDGE.md
